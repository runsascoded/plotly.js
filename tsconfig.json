{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false
    },
    "include": ["src/**/*.ts", "src/**/*.js", "types/**/*.ts"],
    "exclude": ["node_modules", "dist", "tmp"]
}
